# .env template for safe GitHub sharing
# Fill in your real values locally, never commit this file with secrets!

# IBKR API
IBKR_API_KEY=
IBKR_API_SECRET=

# Discord Webhook (optional)
DISCORD_WEBHOOK_URL=

# Other environment variables
LIVE_TRADING_CONFIRM=
EXECUTION_BROKER=ibkr
TEST_PROFILE=

# Add any other required secrets or config here
